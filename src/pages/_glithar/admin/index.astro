---
import Base from "../../../layouts/Base.astro";
import {
	groupByProductionStatus,
	isInterventionPost,
	listAdminPosts,
} from "../../../lib/ar/admin";
import { requireAdminPage } from "../../../lib/ar/http";

const denied = requireAdminPage(Astro);
if (denied) return denied;

const posts = await listAdminPosts(Astro.locals.emdash);
const interventions = posts.filter(isInterventionPost);
const counts = groupByProductionStatus(interventions);
const recent = interventions.slice(0, 12);
---

<Base title="Glithar AR Studio" description="AR production dashboard">
	<section class="ar-admin">
		<header class="ar-header">
			<div>
				<p class="eyebrow">Glithar AR Studio</p>
				<h1>Production Dashboard</h1>
			</div>
			<a class="button" href="/_glithar/admin/ideas">Idea Generator</a>
		</header>

		<div class="metric-grid">
			<div class="metric"><span>Drafts</span><strong>{counts.draft ?? 0}</strong></div>
			<div class="metric"><span>Ready</span><strong>{counts.ready ?? 0}</strong></div>
			<div class="metric"><span>Failed</span><strong>{counts.error ?? 0}</strong></div>
			<div class="metric"><span>Published</span><strong>{counts.published ?? 0}</strong></div>
		</div>

		<section class="panel">
			<div class="panel-heading">
				<h2>Interventions</h2>
				<a href="/_emdash/admin/content/posts">Open EmDash Posts</a>
			</div>
			{
				recent.length === 0 ? (
					<p class="empty">No intervention drafts yet.</p>
				) : (
					<div class="intervention-list">
						{recent.map((post) => (
							<a class="row" href={`/_glithar/admin/interventions/${post.id}`}>
								<span>
									<strong>{post.data.title ?? post.slug ?? post.id}</strong>
									<small>{post.slug}</small>
								</span>
								<code>{post.data.production_status ?? "draft"}</code>
							</a>
						))}
					</div>
				)
			}
		</section>
	</section>
</Base>

<style>
	.ar-admin {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}
	.ar-header,
	.panel-heading,
	.row {
		display: flex;
		justify-content: space-between;
		gap: var(--spacing-4);
		align-items: center;
	}
	.eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
	}
	h1 {
		font-size: var(--font-size-4xl);
		letter-spacing: var(--tracking-tight);
	}
	.button {
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		padding: var(--spacing-2) var(--spacing-4);
		border-radius: var(--radius);
		font-weight: 600;
	}
	.metric-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-4);
		margin: var(--spacing-8) 0;
	}
	.metric,
	.panel {
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
	}
	.metric {
		padding: var(--spacing-5);
	}
	.metric span,
	.row small {
		display: block;
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}
	.metric strong {
		font-size: var(--font-size-3xl);
	}
	.panel {
		padding: var(--spacing-6);
	}
	.intervention-list {
		margin-top: var(--spacing-4);
		border-top: 1px solid var(--color-border-subtle);
	}
	.row {
		color: inherit;
		text-decoration: none;
		padding: var(--spacing-4) 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}
	code {
		font-family: var(--font-mono);
		color: var(--color-accent);
	}
	.empty {
		color: var(--color-muted);
	}
	@media (max-width: 720px) {
		.metric-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.ar-header {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
