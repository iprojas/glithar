---
import Base from "../layouts/Base.astro";
---

<Base title="Discover" description="Local intervention discovery counter">
	<section class="discover">
		<p class="eyebrow">Local Test</p>
		<h1><span id="count">0</span> Seen</h1>
		<p id="updated">This browser has not opened a public intervention page.</p>
	</section>
	<script is:inline>
		const key = "glithar.discover.pagesSeen";
		try {
			const parsed = JSON.parse(localStorage.getItem(key) || "{}");
			const count = Number(parsed.count || 0);
			document.getElementById("count").textContent = String(count);
			if (parsed.updated_at) {
				document.getElementById("updated").textContent = `Updated ${new Date(parsed.updated_at).toLocaleString()}`;
			}
		} catch {
			document.getElementById("count").textContent = "0";
		}
	</script>
</Base>

<style>
	.discover {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
		text-align: center;
	}
	.eyebrow {
		color: var(--color-accent);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
	}
	h1 {
		font-size: 7rem;
		line-height: 1;
		letter-spacing: var(--tracking-tight);
	}
	p:last-child {
		margin-top: var(--spacing-4);
		color: var(--color-muted);
	}
	@media (max-width: 720px) {
		h1 {
			font-size: 4rem;
		}
	}
</style>
