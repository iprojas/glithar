{
  "name": "glithar",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "emdash": {
    "seed": "seed/seed.json"
  },
  "scripts": {
    "dev": "emdash dev",
    "schema:local": "emdash seed seed/seed.json --database data.db --on-conflict update --no-content",
    "build": "bun run schema:local && EMDASH_DATABASE_URL=file:./data.db astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy",
    "typecheck": "bun run schema:local && EMDASH_DATABASE_URL=file:./data.db astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@emdash-cms/cloudflare": "^0.24.1",
    "@emdash-cms/plugin-forms": "^0.2.4",
    "astro": "^7.0.0",
    "emdash": "^0.24.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260305.1",
    "wrangler": "^4.99.0"
  },
  "packageManager": "bun@1.3.14"
}
